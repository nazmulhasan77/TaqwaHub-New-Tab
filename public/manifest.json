{
  "manifest_version": 3,
  "name": "Taqwa Hub - New Tab",
  "version": "1.0.3",
  "description": "Every New Tab, A Step Closer to Allah.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": [
    "https://api.aladhan.com/*",
    "https://api.alquran.cloud/*",
    "https://api.dictionaryapi.dev/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
